{%- comment -%}
  Announcement Banner
  -----------------------------------------------------------------------------
  Site-wide announcement banner displayed at the top of the website (header
  section group), adapted from the Bluestout sections library.

  Features:
  - Customizable background color, font color, font size, top/bottom padding
  - Block-based messages - add as many individual message blocks as needed
  - Template visibility - per-page-type show/hide controls
  - Country visibility - show only for specified ISO country codes (Shopify Markets)
  - Slider mode - fade transitions with configurable timing and nav arrows
  - Marquee mode - continuous scroll, configurable speed + direction (LTR / RTL)
  -----------------------------------------------------------------------------
{%- endcomment -%}

{% stylesheet %}
  .bst-announcement-banner {
    background-color: var(--banner-background-color, #1a1a1a);
    color: var(--banner-text-color, #ffffff);
    font-size: var(--banner-font-size, 14px);
    padding-block-start: var(--banner-padding-top, 10px);
    padding-block-end: var(--banner-padding-bottom, 10px);
    width: 100%;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }

  .bst-ab__slider {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
  }

  .bst-ab__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: 100%;
    max-width: 860px;
    margin-inline: auto;
    text-align: center;
  }

  .bst-ab__slides > * {
    grid-area: stack;
  }

  .bst-ab__slide {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    padding-inline: 8px;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--banner-fade-duration, 500ms) ease-in-out,
      visibility var(--banner-fade-duration, 500ms) ease-in-out;
    position: relative;

    &.is-active {
      opacity: 1;
      visibility: visible;
    }
  }

  .bst-ab__icon {
    flex-shrink: 0;
    line-height: 1;
  }

  .bst-ab__text {
    line-height: 1.4;
  }

  .bst-ab__slide-link {
    position: absolute;
    inset: 0;
  }

  .bst-ab__arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 8px;
    opacity: 0.65;
    transition: opacity 0.2s ease;
    z-index: 1;

    &:hover {
      opacity: 1;
    }

    &:focus-visible {
      outline: 2px solid currentColor;
      outline-offset: 2px;
      border-radius: 2px;
    }

    @media screen and (max-width: 749px) {
      padding: 4px;
    }
  }

  .bst-ab__marquee-outer {
    width: 100%;
    overflow: hidden;
  }

  .bst-ab__marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
    column-gap: 50px;
  }

  .bst-ab__marquee-track.bst-marquee-animate {
    animation: bst-marquee-scroll-left var(--marquee-animation-duration, 20s) linear infinite;
  }

  .bst-ab__marquee-track.bst-marquee-animate.bst-marquee--scroll-right {
    animation-name: bst-marquee-scroll-right;
  }

  .bst-ab__marquee-outer--pauseable:hover .bst-ab__marquee-track.bst-marquee-animate {
    animation-play-state: paused;
  }

  .bst-ab__marquee-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--marquee-item-gap, 80px);
    flex-shrink: 0;
  }

  .bst-ab__marquee-item {
    display: flex;
    align-items: center;
    gap: 0.45em;
    white-space: nowrap;
  }

  .bst-ab__marquee-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(255, 255, 255, 0.5);

    &:hover {
      text-decoration-color: currentColor;
    }
  }

  @keyframes bst-marquee-scroll-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-1 * var(--marquee-scroll-distance, 50%)));
    }
  }

  @keyframes bst-marquee-scroll-right {
    from {
      transform: translateX(calc(-1 * var(--marquee-scroll-distance, 50%)));
    }
    to {
      transform: translateX(0);
    }
  }

  @media screen and (max-width: 749px) {
    .bst-announcement-banner {
      font-size: max(12px, var(--banner-font-size, 14px));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bst-ab__slide {
      transition: none;
    }

    .bst-ab__marquee-track.bst-marquee-animate {
      animation: none;
    }
  }
{% endstylesheet %}

{%- liquid
  assign current_page = request.page_type
  assign visitor_country = localization.country.iso_code | upcase
  assign visible_block_count = 0

  for block in section.blocks
    assign block_enabled_pages = 0
    if block.settings.show_on_index
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_product
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_collection
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_cart
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_page
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_blog
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif
    if block.settings.show_on_search
      assign block_enabled_pages = block_enabled_pages | plus: 1
    endif

    # If no pages checked - show everywhere; otherwise match current page
    assign is_block_visible = false
    if block_enabled_pages == 0
      assign is_block_visible = true
    else
      if block.settings.show_on_index and current_page == 'index'
        assign is_block_visible = true
      endif
      if block.settings.show_on_product and current_page == 'product'
        assign is_block_visible = true
      endif
      if block.settings.show_on_collection and current_page == 'collection'
        assign is_block_visible = true
      endif
      if block.settings.show_on_cart and current_page == 'cart'
        assign is_block_visible = true
      endif
      if block.settings.show_on_page and current_page == 'page'
        assign is_block_visible = true
      endif
      if block.settings.show_on_blog
        if current_page == 'blog' or current_page == 'article'
          assign is_block_visible = true
        endif
      endif
      if block.settings.show_on_search and current_page == 'search'
        assign is_block_visible = true
      endif
    endif

    # Country check - blank means show everywhere
    if is_block_visible and block.settings.allowed_countries != blank
      assign block_country_list = block.settings.allowed_countries | upcase | remove: ' ' | split: ','
      unless block_country_list contains visitor_country
        assign is_block_visible = false
      endunless
    endif

    if is_block_visible
      assign visible_block_count = visible_block_count | plus: 1
    endif
  endfor
-%}

{%- if visible_block_count > 0 -%}
  <section
    id="bst-ab-{{ section.id }}"
    class="bst-announcement-banner"
    data-section-id="{{ section.id }}"
    data-display-mode="{{ section.settings.display_mode }}"
    aria-label="Announcement banner"
    role="region"
    style="
      --banner-background-color: {{ section.settings.bg_color }};
      --banner-text-color: {{ section.settings.font_color }};
      --banner-font-size: {{ section.settings.font_size }}px;
      --banner-padding-top: {{ section.settings.padding_top }}px;
      --banner-padding-bottom: {{ section.settings.padding_bottom }}px;
      --banner-fade-duration: {{ section.settings.transition_speed }}ms;
      --marquee-scroll-speed: {{ section.settings.marquee_speed }};
      --marquee-item-gap: {{ section.settings.marquee_gap }}px;
    "
  >
    {%- if section.settings.display_mode == 'slider' -%}
      <bst-announcement-slider
        class="bst-ab__slider"
        data-slide-duration="{{ section.settings.slide_duration | times: 1000 }}"
      >
        {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
          <button
            class="bst-ab__arrow bst-ab__arrow--prev"
            aria-label="Previous announcement"
            type="button"
          >
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true" focusable="false">
              <path d="M7 1L1 7l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}

        {%- assign first_slide_rendered = false -%}
        <div class="bst-ab__slides">
          {%- for block in section.blocks -%}
            {%- liquid
              assign block_enabled_pages = 0
              if block.settings.show_on_index
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_product
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_collection
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_cart
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_page
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_blog
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif
              if block.settings.show_on_search
                assign block_enabled_pages = block_enabled_pages | plus: 1
              endif

              assign is_block_visible = false
              if block_enabled_pages == 0
                assign is_block_visible = true
              else
                if block.settings.show_on_index and current_page == 'index'
                  assign is_block_visible = true
                endif
                if block.settings.show_on_product and current_page == 'product'
                  assign is_block_visible = true
                endif
                if block.settings.show_on_collection and current_page == 'collection'
                  assign is_block_visible = true
                endif
                if block.settings.show_on_cart and current_page == 'cart'
                  assign is_block_visible = true
                endif
                if block.settings.show_on_page and current_page == 'page'
                  assign is_block_visible = true
                endif
                if block.settings.show_on_blog
                  if current_page == 'blog' or current_page == 'article'
                    assign is_block_visible = true
                  endif
                endif
                if block.settings.show_on_search and current_page == 'search'
                  assign is_block_visible = true
                endif
              endif

              if is_block_visible and block.settings.allowed_countries != blank
                assign block_country_list = block.settings.allowed_countries | upcase | remove: ' ' | split: ','
                unless block_country_list contains visitor_country
                  assign is_block_visible = false
                endunless
              endif
            -%}

            {%- if is_block_visible -%}
              {%- comment -%} Mark the first visible slide as active, not the first in schema order {%- endcomment -%}
              {%- unless first_slide_rendered -%}
                {%- assign is_first_slide = true -%}
                {%- assign first_slide_rendered = true -%}
              {%- else -%}
                {%- assign is_first_slide = false -%}
              {%- endunless -%}
              <div
                class="bst-ab__slide{% if is_first_slide %} is-active{% endif %}"
                aria-hidden="{% if is_first_slide %}false{% else %}true{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.icon != blank -%}
                  <span class="bst-ab__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                {%- endif -%}

                <span class="bst-ab__text">{{ block.settings.text }}</span>

                {%- if block.settings.link != blank -%}
                  {%- comment -%} Full-slide invisible link - readable text set via aria-label {%- endcomment -%}
                  <a
                    class="bst-ab__slide-link"
                    href="{{ block.settings.link }}"
                    aria-label="{{ block.settings.text | strip_html }}"
                  ></a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
          <button
            class="bst-ab__arrow bst-ab__arrow--next"
            aria-label="Next announcement"
            type="button"
          >
            <svg width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true" focusable="false">
              <path d="M1 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {%- endif -%}
      </bst-announcement-slider>

    {%- elsif section.settings.display_mode == 'marquee' -%}
      <div
        class="bst-ab__marquee-outer{% if section.settings.marquee_pause_hover %} bst-ab__marquee-outer--pauseable{% endif %}"
        data-direction="{{ section.settings.marquee_direction }}"
        aria-label="Scrolling announcements"
      >
        <div class="bst-ab__marquee-track" data-marquee-track>
          {%- comment -%} data-marquee-original marks the primary list for JS measurement {%- endcomment -%}
          <ul class="bst-ab__marquee-list" data-marquee-original aria-label="Announcements">
            {%- for block in section.blocks -%}
              {%- liquid
                assign block_enabled_pages = 0
                if block.settings.show_on_index
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_product
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_collection
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_cart
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_page
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_blog
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif
                if block.settings.show_on_search
                  assign block_enabled_pages = block_enabled_pages | plus: 1
                endif

                assign is_block_visible = false
                if block_enabled_pages == 0
                  assign is_block_visible = true
                else
                  if block.settings.show_on_index and current_page == 'index'
                    assign is_block_visible = true
                  endif
                  if block.settings.show_on_product and current_page == 'product'
                    assign is_block_visible = true
                  endif
                  if block.settings.show_on_collection and current_page == 'collection'
                    assign is_block_visible = true
                  endif
                  if block.settings.show_on_cart and current_page == 'cart'
                    assign is_block_visible = true
                  endif
                  if block.settings.show_on_page and current_page == 'page'
                    assign is_block_visible = true
                  endif
                  if block.settings.show_on_blog
                    if current_page == 'blog' or current_page == 'article'
                      assign is_block_visible = true
                    endif
                  endif
                  if block.settings.show_on_search and current_page == 'search'
                    assign is_block_visible = true
                  endif
                endif

                if is_block_visible and block.settings.allowed_countries != blank
                  assign block_country_list = block.settings.allowed_countries | upcase | remove: ' ' | split: ','
                  unless block_country_list contains visitor_country
                    assign is_block_visible = false
                  endunless
                endif
              -%}

              {%- if is_block_visible -%}
                <li class="bst-ab__marquee-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="bst-ab__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                  {%- endif -%}

                  {%- if block.settings.link != blank -%}
                    <a class="bst-ab__marquee-link" href="{{ block.settings.link }}">{{ block.settings.text }}</a>
                  {%- else -%}
                    <span>{{ block.settings.text }}</span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </section>

  {%- comment -%} Standalone JS - no theme framework dependencies {%- endcomment -%}
  <script type="text/javascript">
    class BstAnnouncementSlider extends HTMLElement {
      #slides = [];
      #currentIndex = 0;
      #timer = null;
      #slideDuration = 5000;
      #paused = false;

      connectedCallback() {
        this.#slides = Array.from(this.querySelectorAll('.bst-ab__slide'));

        // Nothing to cycle if there is only one (or zero) slides
        if (this.#slides.length <= 1) return;

        this.#slideDuration = parseInt(this.dataset.slideDuration, 10) || 5000;

        // Wire up navigation arrows (they are optional - only rendered when enabled)
        this.querySelector('.bst-ab__arrow--prev')?.addEventListener('click', () => this.#goTo(this.#currentIndex - 1));
        this.querySelector('.bst-ab__arrow--next')?.addEventListener('click', () => this.#goTo(this.#currentIndex + 1));

        // Pause auto-advance while the cursor is inside the banner
        this.addEventListener('mouseenter', this.#suspend);
        this.addEventListener('mouseleave', this.#resume);

        // Stop the timer when the page is backgrounded, restart when it returns
        document.addEventListener('visibilitychange', this.#handleVisibilityChange);

        this.#startTimer();
      }

      disconnectedCallback() {
        this.#suspend();
        document.removeEventListener('visibilitychange', this.#handleVisibilityChange);
      }

      /** Advance (positive delta) or retreat (negative delta) by one slide. */
      #goTo(index) {
        const count = this.#slides.length;
        // Modulo wrap, handling negative values correctly
        const next = ((index % count) + count) % count;

        this.#slides[this.#currentIndex].classList.remove('is-active');
        this.#slides[this.#currentIndex].setAttribute('aria-hidden', 'true');

        this.#currentIndex = next;

        this.#slides[this.#currentIndex].classList.add('is-active');
        this.#slides[this.#currentIndex].setAttribute('aria-hidden', 'false');
      }

      /** Start the auto-advance interval (clears any existing one first). */
      #startTimer() {
        if (this.#paused) return;
        this.#suspend(); // Clear any stale interval
        this.#timer = setInterval(() => {
          // Double-check hover/visibility state inside the tick as a safety net
          if (!this.matches(':hover') && !document.hidden) {
            this.#goTo(this.#currentIndex + 1);
          }
        }, this.#slideDuration);
      }

      /** Clear the interval without marking the slider as user-paused. */
      #suspend = () => {
        if (this.#timer !== null) {
          clearInterval(this.#timer);
          this.#timer = null;
        }
      };

      /** Restart the timer if the slider is not user-paused. */
      #resume = () => {
        if (!this.#paused) this.#startTimer();
      };

      #handleVisibilityChange = () => {
        document.hidden ? this.#suspend() : this.#resume();
      };
    }
    // Register only once - guard against double-registration (e.g. theme editor reloads)
    if (!customElements.get('bst-announcement-slider')) {
      customElements.define('bst-announcement-slider', BstAnnouncementSlider);
    }
    /* -----------------------------------------------------------------------
   MARQUEE - Initializer function
   ----------------------------------------------------------------------- */
    function initMarquee(section) {
      const outer = section.querySelector('.bst-ab__marquee-outer');
      const track = section.querySelector('[data-marquee-track]');
      const originalList = section.querySelector('[data-marquee-original]');

      if (!outer || !track || !originalList) return;

      const direction = outer.dataset.direction || 'left';

      // Speed is stored as a unitless number on the CSS custom property (px/s)
      const speedRaw = getComputedStyle(section).getPropertyValue('--marquee-scroll-speed').trim();
      const speed = parseFloat(speedRaw) || 60;

      // -- Clone the list for seamless looping --------------------------------
      const clone = originalList.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true'); // Screen readers only read the original
      clone.removeAttribute('data-marquee-original');
      track.appendChild(clone);

      // -- Apply direction class ----------------------------------------------
      if (direction === 'right') {
        track.classList.add('bst-marquee--scroll-right');
      }

      // -- Calculate and apply animation parameters ---------------------------
      function applyAnimation() {
        const listWidth = originalList.offsetWidth;
        if (!listWidth) return; // Not yet painted - ResizeObserver will fire again

        const duration = listWidth / speed;

        track.style.setProperty('--marquee-scroll-distance', `${listWidth}px`);
        track.style.setProperty('--marquee-animation-duration', `${duration}s`);

        // Activate the animation (class is what triggers the CSS keyframes)
        track.classList.add('bst-marquee-animate');
      }

      // -- Use rAF so the DOM has been painted before we measure ---------------
      requestAnimationFrame(applyAnimation);

      // -- Recalculate on resize (handles viewport changes, font-load reflow, etc.)
      const ro = new ResizeObserver(() => {
        track.classList.remove('bst-marquee-animate');
        requestAnimationFrame(applyAnimation);
      });

      ro.observe(originalList);
    }
    /**
     * Initialise all announcement-banner sections currently in the DOM.
     * Called on DOMContentLoaded and on Shopify editor section:load events.
     */
    function initAll() {
      document.querySelectorAll('.bst-announcement-banner[data-display-mode="marquee"]').forEach(initMarquee);
    }

    // Run on initial page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }

    /**
     * Re-initialise when the Shopify theme editor reloads a section.
     * This fires when a merchant changes a setting in the Customizer.
     */
    document.addEventListener('shopify:section:load', (event) => {
      const section = event.target.querySelector('.bst-announcement-banner');
      if (!section) return;

      if (section.dataset.displayMode === 'marquee') {
        initMarquee(section);
      }
      // Custom element re-connects automatically; no manual slider init needed.
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Banner",
  "class": "bst-announcement-banner-section",
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Message Text",
          "default": "Free shipping on all orders over $100"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "Makes the entire message clickable."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon / Emoji (optional)",
          "info": "Displayed before the message text. Accepts any emoji or character."
        },
        {
          "type": "header",
          "content": "Page Visibility"
        },
        {
          "type": "paragraph",
          "content": "Select which page types show this message. Leave ALL unchecked to display on every page."
        },
        {
          "type": "checkbox",
          "id": "show_on_index",
          "label": "Homepage",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_product",
          "label": "Product Pages",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_collection",
          "label": "Collection Pages",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_cart",
          "label": "Cart Page",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_page",
          "label": "Static Pages",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_blog",
          "label": "Blog & Article Pages",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_on_search",
          "label": "Search Page",
          "default": true
        },
        {
          "type": "header",
          "content": "Country Visibility"
        },
        {
          "type": "text",
          "id": "allowed_countries",
          "label": "Allowed Countries",
          "info": "Leave blank to show everywhere. Common codes - Americas: US CA MX BR AR. Europe: GB DE FR IT ES NL SE NO DK FI PL. Asia-Pacific: AU NZ JP KR CN IN SG HK TW MY TH. Middle East & Africa: AE SA ZA EG NG KE.",
          "placeholder": "US,CA"
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Display Mode"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display Mode",
      "options": [
        { "value": "slider", "label": "Slider (fade between messages)" },
