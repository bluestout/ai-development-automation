# ─── AI Development Automation — Railway app env ────────────────────────────
# Copy to .env for local dev. On Railway, set these as service variables.

# Claude Agent SDK (Dev AI). Same key as before.
ANTHROPIC_API_KEY=sk-ant-...

# Per-store Shopify Admin API tokens. Stores are NOT all in one Partner org,
# so this is a JSON map keyed by the store's myshopify domain.
# The task's "Shopify Store" ClickUp field must match a key here exactly.
SHOPIFY_TOKENS={"client-one.myshopify.com":"shpat_xxx","client-two.myshopify.com":"shpat_yyy"}

# ClickUp API token (same as before) — used to read tasks + post comments.
CLICKUP_API_KEY=pk_...

# Shared secret returned when you register the ClickUp webhook. Used to verify
# the X-Signature header on every incoming webhook. See register-webhook script.
CLICKUP_WEBHOOK_SECRET=

# Single GitHub PAT with repo access to ALL client repos (clone + push).
# Classic PAT: "repo" scope. Fine-grained: Contents read/write on each repo.
GITHUB_TOKEN=ghp_...

# Optional Figma file-read PAT. When set, the agent fetches linked designs.
FIGMA_TOKEN=

# Where persistent per-client clones live. On Railway, mount a volume at /data.
VOLUME_DIR=/data/repos

# Provided by Railway in production; defaults to 3000 locally.
PORT=3000
